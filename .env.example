# Azure AI Foundry Multi-Agent Research System Configuration

# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com/openai/v1/chat/completions
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=phi-4-mini-reasoning
AZURE_OPENAI_API_VERSION=2024-02-01

# Azure AI Foundry Configuration
AZURE_FOUNDRY_ENDPOINT=https://ai.azure.com/api/foundry
AZURE_FOUNDRY_PROJECT=your-project-name
AZURE_FOUNDRY_API_KEY=your-foundry-api-key

# MCP Server Configuration
FOUNDRY_URL_FOR_WEB_SEARCH=https://your-resource.services.ai.azure.com/api/projects/your-project/toolboxes/your-toolbox/mcp?api-version=v1
MCP_AUTH_TOKEN=your-mcp-token

# A2A Protocol Configuration
A2A_HOST=0.0.0.0
A2A_PORT=8080
A2A_TIMEOUT=30

# Agent Configuration
AGENT_TEMPERATURE=0.7
AGENT_MAX_TOKENS=4000
AGENT_RETRY_ATTEMPTS=3

# Web Search Configuration
WEB_SEARCH_MAX_RESULTS=10
WEB_SEARCH_TIMEOUT=15

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json